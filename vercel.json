{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "regions": ["hnd1"],
  "functions": {
    "src/app/api/**": {
      "maxDuration": 10
    }
  },
"headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/uploads/(.*)", "destination": "/api/uploads/$1" }
  ]
}
